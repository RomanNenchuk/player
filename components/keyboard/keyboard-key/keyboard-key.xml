<?xml version="1.0" encoding="utf-8" ?>
<component name="KeyboardKey" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/keyboard/keyboard-key/keyboard-key.brs" />
    <script type="text/brightscript" uri="pkg:/components/constants/keyboard-constants.brs" />

    <interface>
        <field id="keyId" type="string" onChange="_onKeyDataChange" />
        <field id="keyTitle" type="string" onChange="_onKeyDataChange" />
        <field id="keyWidth" type="integer" onChange="_onKeyDataChange" />
        <field id="keyHeight" type="integer" value="0" onChange="_onKeyDataChange" />
        <field id="colorFocused" type="string" value="" onChange="_updateFocusVisual" />
        <field id="colorDefault" type="string" value="" onChange="_updateFocusVisual" />
    </interface>

    <children>
        <Rectangle id="background_rect" width="100" height="100" color="0x222222FF" />
        <Label 
            id="letter_label" 
            width="100" 
            height="100" 
            horizAlign="center" 
            vertAlign="center" 
            color="0xFFFFFFFF" 
            font="font:MediumSystemFont" />

        <Poster 
            id="icon_poster" 
            width="40" 
            height="40" 
            translation="[25, 25]" 
            visible="false" 
            loadDisplayMode="scaleToFit" />
    </children>

</component>
