<?xml version="1.0" encoding="utf-8" ?>
<component name="TopMenuItem" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/top-menu/top-menu-item/top-menu-item.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="_onContentChange" />
        <field id="focusPercent" type="float" onChange="_updateVisualState" />
        <field id="itemHasFocus" type="boolean" onChange="_updateVisualState" />
    </interface>

    <children>

        <Poster 
            id="tabIcon"
            width="40" 
            height="40"
            translation="[105, 5]" 
            visible="false"
            loadDisplayMode="scaleToFit" />

        <Label
            id="tabLabel"
            width="250"
            height="50"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallSystemFont"
            color="0xAAAAAAFF" />

        <Rectangle
            id="focusIndicator"
            width="150"
            height="4"
            translation="[50, 46]"
            color="0xE62B1EFF"
            visible="false" />

    </children>

</component>
