<?xml version="1.0" encoding="utf-8" ?>
<component name="VideoCardItem" extends="Group">
    <script type="text/brightscript" uri="pkg:/components/video-card-item/video-card-item.brs" />
      <script type="text/brightscript" uri="pkg:/components/utils/time-formatter.brs" />
    
    <interface>
        <field id="itemContent" type="node" onChange="_onContentChange" />
    </interface>

    <children>
        <Poster id="poster" width="400" height="225" loadDisplayMode="scaleToFill" />
        
        <Rectangle id="durationBg" color="0x000000CC" width="70" height="30" translation="[320, 185]">
            <Label 
                id="durationLabel" 
                width="70" 
                height="30" 
                horizAlign="center" 
                vertAlign="center" 
                color="0xFFFFFFFF" 
                font="font:SmallestSystemFont" />
        </Rectangle>
        
        <Label 
            id="titleLabel" 
            width="400" 
            translation="[0, 245]" 
            color="0xFFFFFFFF" 
            font="font:SmallestBoldSystemFont" 
            numLines="1" 
            wrap="false" />
        
        <Label 
            id="dateLabel" 
            width="400" 
            translation="[0, 280]" 
            color="0xAAAAAAFF" 
            font="font:TinySystemFont" 
            numLines="1" 
            wrap="false" />
    </children>
</component>
