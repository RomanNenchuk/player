<?xml version="1.0" encoding="utf-8" ?>
<component name="TopMenuItem" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/top-menu/top-menu-item/top-menu-item.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="_onContentChange" />
    </interface>

    <children>

        <Poster 
            id="tabIcon"
            width="40" 
            height="40"
            translation="[80, 5]" 
            visible="false"
            loadDisplayMode="scaleToFit" />

        <Label
            id="tabLabel"
            width="200"
            height="50"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallSystemFont"
            color="0x888888FF" />

        <Label
            id="tabLabelBold"
            width="200"
            height="50"
            horizAlign="center"
            vertAlign="center"
            font="font:SmallBoldSystemFont"
            color="0xFFFFFFFF"
            visible="false" />

        <Rectangle
            id="focusIndicator"
            width="140"
            height="4"
            translation="[30, 46]"
            color="0xE62B1EFF"
            visible="false" />

    </children>

</component>
