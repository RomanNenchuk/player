<?xml version="1.0" encoding="utf-8" ?>
<component name="SearchScreen" extends="BaseScreen">

    <interface>
        <field id="feedData" type="node" alwaysNotify="true" onChange="_onFeedDataReceived" />
    </interface>

    <script type="text/brightscript" uri="pkg:/components/screens/search-screen/search-screen.brs" />
    <script type="text/brightscript" uri="pkg:/components/services/video-feed-service.brs" />
    <script type="text/brightscript" uri="pkg:/components/utils/navigation-utils.brs" />

    <children>
        <Group id="left_panel" translation="[100, 150]">
        
            <Group id="voice_prompt_group" visible="false" translation="[0, 0]">
                <Group id="mic_button_large" translation="[0, 0]">
                    <Poster 
                        id="mic_bg"
                        uri="pkg:/images/mic_bg.png" 
                        width="64" 
                        height="64" 
                    />
                    <Poster 
                        id="mic_icon_large" 
                        uri="pkg:/images/mic_icon.png" 
                        width="28"
                        height="28"
                        translation="[18, 18]" 
                        blendColor="0xFFFFFFFF" 
                    />
                </Group>

                <LayoutGroup 
                    layoutDirection="horiz" 
                    vertAlignment="center" 
                    itemSpacings="[10, 10]"
                    translation="[80, 32]"
                >
                    <Label text="Press and Hold" color="0x888888FF" font="font:TinySystemFont" />
                    <Poster uri="pkg:/images/mic_icon.png" width="22" height="22" blendColor="0x888888FF" />
                    <Label text="while you speak" color="0x888888FF" font="font:TinySystemFont" />
                </LayoutGroup>
            </Group>

            <CustomKeyboard id="keyboard" translation="[0, 100]" />

        </Group>

        <Group id="right_panel" translation="[900, 150]"> 
            <Group id="search_header_group" translation="[0,0]">
                
                <Poster 
                    id="search_header_bg" 
                    uri="pkg:/images/pill_bg.9.png" 
                    height="64" />

                <Label 
                    id="search_header_label" 
                    text="What are you looking for?" 
                    color="0xCCCCCCFF" 
                    font="font:SmallerSystemFont"
                    wrap="false"/>
            
            </Group>

            <MarkupGrid
                id="searchResultsGrid"
                translation="[0, 100]"
                itemComponentName="RowListItem"
                itemSize="[400, 310]"
                itemSpacing="[30, 30]"
                numColumns="2"
                numRows="2"
                height="800"
                visible="false" />
                
        </Group>

        <Timer id="debounce_timer" duration="0.4" repeat="false" />
    </children>

</component>
