<?xml version="1.0" encoding="utf-8" ?>
<component name="VoicePrompt" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/voice-prompt/voice-prompt.brs" />

    <children>
        <Group id="micButtonLarge" translation="[0, 0]">
            <Poster
                id="micBg"
                uri="pkg:/images/mic_bg.png"
                width="64"
                height="64"
            />
            <Poster
                id="micIconLarge"
                uri="pkg:/images/mic_icon.png"
                width="28"
                height="28"
                translation="[18, 18]"
                blendColor="0xFFFFFFFF"
            />
        </Group>

        <LayoutGroup
            layoutDirection="horiz"
            vertAlignment="center"
            itemSpacings="[10, 10]"
            translation="[80, 32]"
