<?xml version="1.0" encoding="utf-8" ?>
<component name="CustomDialogButton" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/custom-dialog/custom-dialog-button/custom-dialog-button.brs" />

    <interface>
        <field id="itemContent" type="node" onChange="onContentChange" />
        <field id="focusPercent" type="float" onChange="onFocusChange" />
    </interface>

    <children>
        <Rectangle 
            id="buttonBackground" 
            width="600" 
            height="60" 
            color="0x00000000" 
        />
        
        <Label 
            id="buttonText" 
            width="600" 
            height="60" 
            horizAlign="center" 
            vertAlign="center" 
            font="font:MediumBoldSystemFont" 
            color="0xFFFFFFFF" 
        />
    </children>

</component>
