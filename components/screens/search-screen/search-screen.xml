<?xml version="1.0" encoding="utf-8" ?>
<component name="SearchScreen" extends="Group" focusable="true">

    <script type="text/brightscript" uri="pkg:/components/screens/search-screen/search-screen.brs" />

    <children>

        <Group id="left_panel" translation="[100, 150]">  
            <LayoutGroup
                id="keyboard_layout_group"
                layoutDirection="vert"
                itemSpacings="[3]"
                translation="[0, 100]"
            />
        </Group>

         <Group id="right_panel" translation="[700, 150]">
            <Label 
                id="empty_state_label" 
                text="What are you looking for?" 
                color="0xFFFFFFFF" 
                font="font:MediumSystemFont" 
                translation="[200, 200]" 
            />
            <Label 
                id="search_results_title" 
                text="" 
                color="0xFFFFFFFF" 
                font="font:MediumSystemFont" 
                visible="false" 
                translation="[0, 0]" 
            />
        </Group>

        <Timer id="debounce_timer" duration="0.4" repeat="false" />
    </children>

</component>
