            <Label text="Press and Hold" color="0x888888FF" font="font:TinySystemFont" />
            <Poster uri="pkg:/images/mic_icon.png" width="22" height="22" blendColor="0x888888FF" />
            <Label text="while you speak" color="0x888888FF" font="font:TinySystemFont" />
        </LayoutGroup>

    </children>

</component>
