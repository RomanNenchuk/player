<?xml version="1.0" encoding="utf-8" ?>
<component name="TopMenu" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/top-menu/top-menu.brs" />

    <interface>
        <field id="itemSelected" type="assocarray" />
        <field id="activeTab" type="string" onChange="_onActiveTabChange" />
    </interface>

    <children>

        <Rectangle
            id="menuBackground"
            width="1920"
            height="120"
            color="0x000000B3" />

        <Poster
            id="tedLogo"
            uri="pkg:/images/logo_mini.jpg"
            width="120"
            height="40"
            translation="[100, 40]"
            loadDisplayMode="scaleToFit" />

        <MarkupGrid
            id="menuGrid"
            translation="[300, 35]"
            numRows="1"
            numColumns="6"
            itemSize="[250, 50]"
            itemSpacing="[10, 0]"
            drawFocusFeedback="false"
            vertFocusAnimationStyle="fixedFocusWrap"
            itemComponentName="TopMenuItem" />

    </children>

</component>
