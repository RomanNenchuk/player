<?xml version="1.0" encoding="utf-8" ?>
<component name="HeroComponent" extends="Group">

    <script type="text/brightscript" uri="pkg:/components/hero-component/hero-component.brs" />

    <interface>
        <field id="content" type="node" onChange="onContentChange" />
        <field id="playSelected" type="boolean" alias="playButton.buttonSelected" />
    </interface>

    <children>
        <LayoutGroup translation="[100, 100]" itemSpacings="[40]">
            <Poster 
                id="thumbnail" 
                width="640" 
                height="360" 
                loadDisplayMode="scaleToFit" />
                
            <Button 
                id="playButton" 
                text="Play Video" 
                minWidth="200"
                iconUri=""
                focusedIconUri="" />
        </LayoutGroup>

        <LayoutGroup translation="[800, 100]" itemSpacings="[20]">
            <Label 
                id="title" 
                width="1000" 
                font="font:LargeBoldSystemFont" 
                wrap="true" />
                
            <Label 
                id="description" 
                width="1000" 
                wrap="true" 
                numLines="15" />
        </LayoutGroup>
    </children>

</component>
